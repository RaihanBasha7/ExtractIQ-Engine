# ── Required ──────────────────────────────────────────────────────────────────
LLM_PROVIDER=featherless
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=google/gemma-4-31B-it
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# ── Optional: Groq as alternate provider ──────────────────────────────────────
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Extraction ────────────────────────────────────────────────────────────────
MAX_REPAIR_RETRIES=3

# ── Database (SQLite default, PostgreSQL with DATABASE_URL) ───────────────────
DB_PATH=data/extractions.db
DATABASE_URL=sqlite:///data/extractions.db
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/extractiq

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# ── Timeouts ──────────────────────────────────────────────────────────────────
# LLM_TIMEOUT_SECONDS=120
# EXTRACTION_TIMEOUT_SECONDS=150
